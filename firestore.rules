rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - email: string (required)
    //   - role: string (required, enum: ['user', 'admin'])
    //   - createdAt: timestamp (optional)
    //
    // Collection: trips
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - type: string (required, enum: ['Hajj', 'Umrah'])
    //   - price: number (required)
    //   - dates: string (required)
    //   - details: string (optional)
    //   - seats: number (required)
    //   - seatsBooked: number (optional)
    //   [... rich fields ...]
    //
    // Collection: bookings
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - tripId: string (required)
    //   - seats: number (required)
    //   - totalPrice: number (required)
    //   - status: string (required)
    //
    // Collection: appointments
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - date: string (required)
    //   - time: string (required)
    //   - status: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "mohdamaan78621@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.uid is string && data.name is string && data.email is string &&
             data.role in ['user', 'admin'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /trips/{tripId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow delete: if isAdmin();
    }

    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pastTrips/{tripId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
